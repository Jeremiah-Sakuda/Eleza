# Server-only OpenAI credential. Never prefix this with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Supabase project URL is public configuration; the service-role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional non-secret capacity setting. Defaults to 200 when omitted.
DEMO_GLOBAL_DAILY_CAP=200

# Optional server-only judge bypass. The code is never included in browser bundles.
JUDGE_ACCESS_CODE=
JUDGE_DAILY_CAP=50
